{"title":"Index","markdown":{"yaml":{"title":"Index","format":{"html":{"css":"styles.css","page-layout":"custom","title-block-style":"none"}},"resources":["data/cities_development.geojson"]},"containsRefs":false,"markdown":"\n\n<!-- ========================================== -->\n<!-- 1. PAGE LAYOUT WRAPPER                     -->\n<!-- ========================================== -->\n::::: {.desktop-index-container}\n\n<!-- ========================================== -->\n<!-- 2. HEADER SECTION                          -->\n<!-- Contains the main title and issue metadata -->\n<!-- ========================================== -->\n::: {.index-header-row}\n::: {.index-title}\n<h1><span class=\"header-section-number\">/00</span> The epoch of the immen-city </h1>\n:::\n::: {.index-meta}\n<p>Issue No. 0<br>July 2025</p>\n:::\n:::\n\n<!-- ========================================== -->\n<!-- 3. INTERACTIVE MAP SECTION                 -->\n<!-- Builds the Mapbox globe and interactions   -->\n<!-- ========================================== -->\n::: {.index-map-box}\n```{=html}\n<!-- 3.1 HTML Setup: Mapbox Dependencies -->\n<script src=\"https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.js\"></script>\n<link href=\"https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.css\" rel=\"stylesheet\" />\n\n<!-- 3.2 Component Styling (Map, Slider, Legend) -->\n<style>\n  #map-container { position: relative; width: 100%; height: 100%; min-height: 450px; }\n  #map { position: absolute; top: 0; bottom: 0; width: 100%; }\n  .slider-panel {\n    position: absolute; bottom: 30px; left: 30px; z-index: 1;\n    background: rgba(255, 255, 255, 0.9); padding: 15px; border-radius: 4px;\n    box-shadow: 0 0 10px rgba(0,0,0,0.1); font-family: sans-serif;\n  }\n  .mapboxgl-popup-content { font-family: sans-serif; font-size: 14px; }\n  \n  .map-overlay {\n    position: absolute;\n    bottom: 30px;\n    right: 30px;\n    background: rgba(255, 255, 255, 0.8);\n    font-family: Arial, sans-serif;\n    overflow: auto;\n    border-radius: 4px;\n    padding: 15px;\n    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n    line-height: 24px;\n    z-index: 1;\n    max-height: 200px;\n  }\n  .legend-key {\n    display: inline-block;\n    border-radius: 50%;\n    width: 12px;\n    height: 12px;\n    margin-right: 8px;\n  }\n</style>\n\n<!-- 3.3 HTML Structure (UI Elements) -->\n<div id=\"map-container\">\n  <div id=\"map\"></div>\n  <div class=\"slider-panel\">\n    <h2>Year: <span id=\"active-year\">1975</span></h2>\n    <input id=\"slider\" type=\"range\" min=\"1975\" max=\"2035\" step=\"5\" value=\"1975\" style=\"width: 200px;\">\n  </div>\n  <div class=\"map-overlay\" id=\"legend\"></div>\n</div>\n\n<!-- 3.4 JavaScript: Mapbox Initialization and Data Engine -->\n<script>\n  mapboxgl.accessToken = 'pk.eyJ1IjoibWFzY2ljbG8iLCJhIjoiY21uMDFlb2QyMGRlYTJwczJ1NXh0NGNwbCJ9.10bjc3pP6ZC8TAXtORUVMw'; \n\n  const map = new mapboxgl.Map({\n      container: 'map',\n      style: 'mapbox://styles/mapbox/light-v11',\n      center: [0, 20],\n      zoom: 1.5,\n      projection: 'globe'\n  });\n\n  map.on('load', () => {\n\n      map.addSource('cities', {\n          type: 'geojson',\n          data: 'data/cities_development.geojson?t=' + new Date().getTime()\n      });\n\n      // --- 3.4.1 Add Proportional Circles Layer ---\n      map.addLayer({\n          'id': 'cities-circles',\n          'type': 'circle',\n          'source': 'cities',\n          'paint': {\n              'circle-color': [\n                  'interpolate',\n                  ['linear'],\n                  ['get', 'pop_1975'],\n                  0, '#fcfdbf',\n                  5, '#feca8d',\n                  10, '#fd9668',\n                  15, '#f1605d',\n                  20, '#cd4071',\n                  25, '#9e2f7f',\n                  30, '#721f81',\n                  35, '#440f76',\n                  40, '#180f3d',\n                  45, '#000004'\n              ],\n              'circle-opacity': 0.8,\n              'circle-stroke-width': 1,\n              'circle-stroke-color': '#ffffff',\n              'circle-radius': ['*', ['get', 'pop_1975'], 1.2]\n          }\n      });\n\n      // --- 3.4.2 Build and Attach the Map Legend ---\n      const legendLayers = ['0M', '5M', '10M', '15M', '20M', '25M', '30M', '35M', '40M', '45M'];\n      const legendColors = ['#fcfdbf', '#feca8d', '#fd9668', '#f1605d', '#cd4071', '#9e2f7f', '#721f81', '#440f76', '#180f3d', '#000004'];\n      \n      const legend = document.getElementById('legend');\n      const legendTitle = document.createElement('strong');\n      legendTitle.innerHTML = 'Population<br>';\n      legend.appendChild(legendTitle);\n\n      legendLayers.forEach((layer, i) => {\n          const color = legendColors[i];\n          const item = document.createElement('div');\n          const key = document.createElement('span');\n          key.className = 'legend-key';\n          key.style.backgroundColor = color;\n      \n          const value = document.createElement('span');\n          value.innerHTML = layer;\n          item.appendChild(key);\n          item.appendChild(value);\n          legend.appendChild(item);\n      });\n\n      // --- 3.4.3 Year Slider Update Function ---\n      // Dynamically styles circle radius and color based on the selected year\n      function setYear(year) {\n          document.getElementById('active-year').innerText = year;\n          map.setPaintProperty('cities-circles', 'circle-radius', ['*', ['get', 'pop_' + year], 1.2]);\n          map.setPaintProperty('cities-circles', 'circle-color', [\n              'interpolate',\n              ['linear'],\n              ['get', 'pop_' + year],\n              0, '#fcfdbf',\n              5, '#feca8d',\n              10, '#fd9668',\n              15, '#f1605d',\n              20, '#cd4071',\n              25, '#9e2f7f',\n              30, '#721f81',\n              35, '#440f76',\n              40, '#180f3d',\n              45, '#000004'\n          ]);\n      }\n\n      setYear(1975);\n\n      document.getElementById('slider').addEventListener('input', (e) => {\n          setYear(e.target.value);\n      });\n\n      // --- 3.4.4 Map Interactivity: Tooltips on Hover ---\n      const popup = new mapboxgl.Popup({\n          closeButton: false,\n          closeOnClick: false\n      });\n\n      map.on('mousemove', 'cities-circles', (e) => {\n          map.getCanvas().style.cursor = 'pointer';\n          const coordinates = e.features[0].geometry.coordinates.slice();\n          const popKey = 'pop_' + document.getElementById('slider').value;\n          const pop = e.features[0].properties[popKey];\n          const name = e.features[0].properties.name;\n\n          while (Math.abs(e.lngLat.lng - coordinates[0]) > 180) {\n              coordinates[0] += e.lngLat.lng > coordinates[0] ? 360 : -360;\n          }\n\n          popup.setLngLat(coordinates)\n              .setHTML(`<strong>${name}</strong><br>Population: ${pop} Million`)\n              .addTo(map);\n      });\n\n      map.on('mouseleave', 'cities-circles', () => {\n          map.getCanvas().style.cursor = '';\n          popup.remove();\n      });\n\n      // --- Auto Tour Animation Logic ---\n      let isAnimating = true;\n      let animationRef;\n\n      function stopAnimation() {\n          if (isAnimating) {\n              isAnimating = false;\n              cancelAnimationFrame(animationRef);\n              map.stop(); // Stop any pending flyTo or panning\n          }\n      }\n\n      // Listen for interruptions\n      map.on('mousedown', stopAnimation);\n      map.on('touchstart', stopAnimation);\n      map.on('wheel', stopAnimation);\n      map.on('dragstart', stopAnimation);\n      document.getElementById('slider').addEventListener('mousedown', stopAnimation);\n      document.getElementById('slider').addEventListener('touchstart', stopAnimation);\n\n      function animateSlider(startTime, startVal, endVal, duration) {\n          return new Promise(resolve => {\n              function step(timestamp) {\n                  if (!isAnimating) return resolve();\n                  \n                  const progress = Math.min((timestamp - startTime) / duration, 1);\n                  // Snap to nearest 5 years\n                  const current = Math.round((startVal + progress * (endVal - startVal)) / 5) * 5;\n                  \n                  // Update slider and map if changed\n                  if (document.getElementById('slider').value != current) {\n                      document.getElementById('slider').value = current;\n                      setYear(current);\n                  }\n                  \n                  if (progress < 1) {\n                      animationRef = requestAnimationFrame(step);\n                  } else {\n                      resolve();\n                  }\n              }\n              animationRef = requestAnimationFrame(step);\n          });\n      }\n\n      async function startTour() {\n          try {\n              const response = await fetch('data/cities_development.geojson');\n              const data = await response.json();\n              if(!data || !data.features || data.features.length === 0) return;\n\n              // Shuffle cities\n              const features = data.features.sort(() => 0.5 - Math.random());\n              let cityIndex = 0;\n              let goingUp = true; // Slider direction\n\n              // Initial delay before starting\n              await new Promise(r => setTimeout(r, 1500));\n\n              async function tourNextCity() {\n                  if (!isAnimating) return;\n                  \n                  if (cityIndex >= features.length) {\n                      // Repeat loop\n                      cityIndex = 0;\n                      features.sort(() => 0.5 - Math.random()); \n                  }\n                  \n                  const city = features[cityIndex];\n                  const coords = city.geometry.coordinates;\n                  const duration = 4000;\n\n                  // Move camera\n                  map.flyTo({\n                      center: coords,\n                      zoom: 4.5,\n                      duration: duration,\n                      essential: true\n                  });\n\n                  const startVal = goingUp ? 1975 : 2035;\n                  const endVal = goingUp ? 2035 : 1975;\n                  \n                  // Sync slider\n                  await animateSlider(performance.now(), startVal, endVal, duration);\n                  \n                  goingUp = !goingUp;\n                  cityIndex++;\n                  \n                  if (isAnimating) {\n                     // Minor pause between flights\n                     await new Promise(r => setTimeout(r, 500));\n                     tourNextCity();\n                  }\n              }\n              \n              tourNextCity();\n\n          } catch (e) {\n              console.error(\"Failed to load cities for tour:\", e);\n          }\n      }\n\n      // Start the sequence\n      startTour();\n\n  });\n</script>\n```\n:::\n\n<!-- ========================================== -->\n<!-- 4. FOOTER SECTION                          -->\n<!-- Navigation links and author information    -->\n<!-- ========================================== -->\n::: {.index-footer-row}\n::: {.index-footer-left}\n<p>Author<br>Jaime Vergara Sanfuentes</p>\n:::\n::: {.index-footer-right}\n<ul>\n  <li><a href=\"index.html\">Index</a></li>\n  <li><a href=\"chap_1.html\">Chapter 1</a></li>\n  <li><a href=\"chap_2.html\">Chapter 2</a></li>\n  <li><a href=\"chap_3.html\">Chapter 3</a></li>\n  <li><a href=\"chap_4.html\">Chapter 4</a></li>\n  <li><a href=\"chap_5.html\">Chapter 5</a></li>\n  <li><a href=\"chap_6.html\">Chapter 6</a></li>\n  \n  <li><a href=\"references.html\">References</a></li>\n</ul>\n:::\n:::\n\n:::::\n","srcMarkdownNoYaml":"\n\n<!-- ========================================== -->\n<!-- 1. PAGE LAYOUT WRAPPER                     -->\n<!-- ========================================== -->\n::::: {.desktop-index-container}\n\n<!-- ========================================== -->\n<!-- 2. HEADER SECTION                          -->\n<!-- Contains the main title and issue metadata -->\n<!-- ========================================== -->\n::: {.index-header-row}\n::: {.index-title}\n<h1><span class=\"header-section-number\">/00</span> The epoch of the immen-city </h1>\n:::\n::: {.index-meta}\n<p>Issue No. 0<br>July 2025</p>\n:::\n:::\n\n<!-- ========================================== -->\n<!-- 3. INTERACTIVE MAP SECTION                 -->\n<!-- Builds the Mapbox globe and interactions   -->\n<!-- ========================================== -->\n::: {.index-map-box}\n```{=html}\n<!-- 3.1 HTML Setup: Mapbox Dependencies -->\n<script src=\"https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.js\"></script>\n<link href=\"https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.css\" rel=\"stylesheet\" />\n\n<!-- 3.2 Component Styling (Map, Slider, Legend) -->\n<style>\n  #map-container { position: relative; width: 100%; height: 100%; min-height: 450px; }\n  #map { position: absolute; top: 0; bottom: 0; width: 100%; }\n  .slider-panel {\n    position: absolute; bottom: 30px; left: 30px; z-index: 1;\n    background: rgba(255, 255, 255, 0.9); padding: 15px; border-radius: 4px;\n    box-shadow: 0 0 10px rgba(0,0,0,0.1); font-family: sans-serif;\n  }\n  .mapboxgl-popup-content { font-family: sans-serif; font-size: 14px; }\n  \n  .map-overlay {\n    position: absolute;\n    bottom: 30px;\n    right: 30px;\n    background: rgba(255, 255, 255, 0.8);\n    font-family: Arial, sans-serif;\n    overflow: auto;\n    border-radius: 4px;\n    padding: 15px;\n    box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);\n    line-height: 24px;\n    z-index: 1;\n    max-height: 200px;\n  }\n  .legend-key {\n    display: inline-block;\n    border-radius: 50%;\n    width: 12px;\n    height: 12px;\n    margin-right: 8px;\n  }\n</style>\n\n<!-- 3.3 HTML Structure (UI Elements) -->\n<div id=\"map-container\">\n  <div id=\"map\"></div>\n  <div class=\"slider-panel\">\n    <h2>Year: <span id=\"active-year\">1975</span></h2>\n    <input id=\"slider\" type=\"range\" min=\"1975\" max=\"2035\" step=\"5\" value=\"1975\" style=\"width: 200px;\">\n  </div>\n  <div class=\"map-overlay\" id=\"legend\"></div>\n</div>\n\n<!-- 3.4 JavaScript: Mapbox Initialization and Data Engine -->\n<script>\n  mapboxgl.accessToken = 'pk.eyJ1IjoibWFzY2ljbG8iLCJhIjoiY21uMDFlb2QyMGRlYTJwczJ1NXh0NGNwbCJ9.10bjc3pP6ZC8TAXtORUVMw'; \n\n  const map = new mapboxgl.Map({\n      container: 'map',\n      style: 'mapbox://styles/mapbox/light-v11',\n      center: [0, 20],\n      zoom: 1.5,\n      projection: 'globe'\n  });\n\n  map.on('load', () => {\n\n      map.addSource('cities', {\n          type: 'geojson',\n          data: 'data/cities_development.geojson?t=' + new Date().getTime()\n      });\n\n      // --- 3.4.1 Add Proportional Circles Layer ---\n      map.addLayer({\n          'id': 'cities-circles',\n          'type': 'circle',\n          'source': 'cities',\n          'paint': {\n              'circle-color': [\n                  'interpolate',\n                  ['linear'],\n                  ['get', 'pop_1975'],\n                  0, '#fcfdbf',\n                  5, '#feca8d',\n                  10, '#fd9668',\n                  15, '#f1605d',\n                  20, '#cd4071',\n                  25, '#9e2f7f',\n                  30, '#721f81',\n                  35, '#440f76',\n                  40, '#180f3d',\n                  45, '#000004'\n              ],\n              'circle-opacity': 0.8,\n              'circle-stroke-width': 1,\n              'circle-stroke-color': '#ffffff',\n              'circle-radius': ['*', ['get', 'pop_1975'], 1.2]\n          }\n      });\n\n      // --- 3.4.2 Build and Attach the Map Legend ---\n      const legendLayers = ['0M', '5M', '10M', '15M', '20M', '25M', '30M', '35M', '40M', '45M'];\n      const legendColors = ['#fcfdbf', '#feca8d', '#fd9668', '#f1605d', '#cd4071', '#9e2f7f', '#721f81', '#440f76', '#180f3d', '#000004'];\n      \n      const legend = document.getElementById('legend');\n      const legendTitle = document.createElement('strong');\n      legendTitle.innerHTML = 'Population<br>';\n      legend.appendChild(legendTitle);\n\n      legendLayers.forEach((layer, i) => {\n          const color = legendColors[i];\n          const item = document.createElement('div');\n          const key = document.createElement('span');\n          key.className = 'legend-key';\n          key.style.backgroundColor = color;\n      \n          const value = document.createElement('span');\n          value.innerHTML = layer;\n          item.appendChild(key);\n          item.appendChild(value);\n          legend.appendChild(item);\n      });\n\n      // --- 3.4.3 Year Slider Update Function ---\n      // Dynamically styles circle radius and color based on the selected year\n      function setYear(year) {\n          document.getElementById('active-year').innerText = year;\n          map.setPaintProperty('cities-circles', 'circle-radius', ['*', ['get', 'pop_' + year], 1.2]);\n          map.setPaintProperty('cities-circles', 'circle-color', [\n              'interpolate',\n              ['linear'],\n              ['get', 'pop_' + year],\n              0, '#fcfdbf',\n              5, '#feca8d',\n              10, '#fd9668',\n              15, '#f1605d',\n              20, '#cd4071',\n              25, '#9e2f7f',\n              30, '#721f81',\n              35, '#440f76',\n              40, '#180f3d',\n              45, '#000004'\n          ]);\n      }\n\n      setYear(1975);\n\n      document.getElementById('slider').addEventListener('input', (e) => {\n          setYear(e.target.value);\n      });\n\n      // --- 3.4.4 Map Interactivity: Tooltips on Hover ---\n      const popup = new mapboxgl.Popup({\n          closeButton: false,\n          closeOnClick: false\n      });\n\n      map.on('mousemove', 'cities-circles', (e) => {\n          map.getCanvas().style.cursor = 'pointer';\n          const coordinates = e.features[0].geometry.coordinates.slice();\n          const popKey = 'pop_' + document.getElementById('slider').value;\n          const pop = e.features[0].properties[popKey];\n          const name = e.features[0].properties.name;\n\n          while (Math.abs(e.lngLat.lng - coordinates[0]) > 180) {\n              coordinates[0] += e.lngLat.lng > coordinates[0] ? 360 : -360;\n          }\n\n          popup.setLngLat(coordinates)\n              .setHTML(`<strong>${name}</strong><br>Population: ${pop} Million`)\n              .addTo(map);\n      });\n\n      map.on('mouseleave', 'cities-circles', () => {\n          map.getCanvas().style.cursor = '';\n          popup.remove();\n      });\n\n      // --- Auto Tour Animation Logic ---\n      let isAnimating = true;\n      let animationRef;\n\n      function stopAnimation() {\n          if (isAnimating) {\n              isAnimating = false;\n              cancelAnimationFrame(animationRef);\n              map.stop(); // Stop any pending flyTo or panning\n          }\n      }\n\n      // Listen for interruptions\n      map.on('mousedown', stopAnimation);\n      map.on('touchstart', stopAnimation);\n      map.on('wheel', stopAnimation);\n      map.on('dragstart', stopAnimation);\n      document.getElementById('slider').addEventListener('mousedown', stopAnimation);\n      document.getElementById('slider').addEventListener('touchstart', stopAnimation);\n\n      function animateSlider(startTime, startVal, endVal, duration) {\n          return new Promise(resolve => {\n              function step(timestamp) {\n                  if (!isAnimating) return resolve();\n                  \n                  const progress = Math.min((timestamp - startTime) / duration, 1);\n                  // Snap to nearest 5 years\n                  const current = Math.round((startVal + progress * (endVal - startVal)) / 5) * 5;\n                  \n                  // Update slider and map if changed\n                  if (document.getElementById('slider').value != current) {\n                      document.getElementById('slider').value = current;\n                      setYear(current);\n                  }\n                  \n                  if (progress < 1) {\n                      animationRef = requestAnimationFrame(step);\n                  } else {\n                      resolve();\n                  }\n              }\n              animationRef = requestAnimationFrame(step);\n          });\n      }\n\n      async function startTour() {\n          try {\n              const response = await fetch('data/cities_development.geojson');\n              const data = await response.json();\n              if(!data || !data.features || data.features.length === 0) return;\n\n              // Shuffle cities\n              const features = data.features.sort(() => 0.5 - Math.random());\n              let cityIndex = 0;\n              let goingUp = true; // Slider direction\n\n              // Initial delay before starting\n              await new Promise(r => setTimeout(r, 1500));\n\n              async function tourNextCity() {\n                  if (!isAnimating) return;\n                  \n                  if (cityIndex >= features.length) {\n                      // Repeat loop\n                      cityIndex = 0;\n                      features.sort(() => 0.5 - Math.random()); \n                  }\n                  \n                  const city = features[cityIndex];\n                  const coords = city.geometry.coordinates;\n                  const duration = 4000;\n\n                  // Move camera\n                  map.flyTo({\n                      center: coords,\n                      zoom: 4.5,\n                      duration: duration,\n                      essential: true\n                  });\n\n                  const startVal = goingUp ? 1975 : 2035;\n                  const endVal = goingUp ? 2035 : 1975;\n                  \n                  // Sync slider\n                  await animateSlider(performance.now(), startVal, endVal, duration);\n                  \n                  goingUp = !goingUp;\n                  cityIndex++;\n                  \n                  if (isAnimating) {\n                     // Minor pause between flights\n                     await new Promise(r => setTimeout(r, 500));\n                     tourNextCity();\n                  }\n              }\n              \n              tourNextCity();\n\n          } catch (e) {\n              console.error(\"Failed to load cities for tour:\", e);\n          }\n      }\n\n      // Start the sequence\n      startTour();\n\n  });\n</script>\n```\n:::\n\n<!-- ========================================== -->\n<!-- 4. FOOTER SECTION                          -->\n<!-- Navigation links and author information    -->\n<!-- ========================================== -->\n::: {.index-footer-row}\n::: {.index-footer-left}\n<p>Author<br>Jaime Vergara Sanfuentes</p>\n:::\n::: {.index-footer-right}\n<ul>\n  <li><a href=\"index.html\">Index</a></li>\n  <li><a href=\"chap_1.html\">Chapter 1</a></li>\n  <li><a href=\"chap_2.html\">Chapter 2</a></li>\n  <li><a href=\"chap_3.html\">Chapter 3</a></li>\n  <li><a href=\"chap_4.html\">Chapter 4</a></li>\n  <li><a href=\"chap_5.html\">Chapter 5</a></li>\n  <li><a href=\"chap_6.html\">Chapter 6</a></li>\n  \n  <li><a href=\"references.html\">References</a></li>\n</ul>\n:::\n:::\n\n:::::\n"},"formats":{"html":{"identifier":{"display-name":"HTML","target-format":"html","base-format":"html"},"execute":{"fig-width":7,"fig-height":5,"fig-format":"retina","fig-dpi":96,"df-print":"default","error":false,"eval":true,"cache":null,"freeze":false,"echo":true,"output":true,"warning":true,"include":true,"keep-md":false,"keep-ipynb":false,"ipynb":null,"enabled":null,"daemon":null